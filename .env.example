# Copy to `.env` and adjust. All values have sane defaults; nothing here is required to run locally.

# --- Prediction API ---
API_HOST=0.0.0.0
API_PORT=8000

# Where the dashboard reaches the API (inside docker-compose use the service name)
DELIVERY_API_URL=http://localhost:8000

# --- Model artifacts ---
MODEL_DIR=models

# --- Weather (Open-Meteo: free, no API key required) ---
WEATHER_BASE_URL=https://api.open-meteo.com/v1/forecast
WEATHER_CACHE_TTL_SECONDS=900

# --- MLflow (local file store by default) ---
MLFLOW_TRACKING_URI=file:./mlruns
MLFLOW_EXPERIMENT=delivery-delay
